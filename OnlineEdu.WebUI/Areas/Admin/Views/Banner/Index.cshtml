@model List<ResultBannerDto>
@{
    ViewData["Title"] = "Banner Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Başlık</th>        
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        count++;
        <tr>
            <td>@count</td>
            <td><img src="@item.ImageUrl" style="height:75px;width:75px"/> <span> </span> @item.Title </td>
            <td>
                <a asp-area="Admin" asp-controller="Banner" asp-action="DeleteBanner" asp-route-id="@item.BannerId" class="btn btn-danger">Sil</a>
                <a asp-area="Admin" asp-controller="Banner" asp-action="UpdateBanner" asp-route-id="@item.BannerId" class="btn btn-primary">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />

<a asp-area="Admin" asp-controller="Banner" asp-action="CreateBanner" class="btn btn-success">Yeni Banner Ekle</a>
