@model List<ResultSocialMediaDto>
@{
    ViewData["Title"] = "Sosyal Medya Alanları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Sosyal Medya</th>
       
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        count++;
        <tr>
            <td>@count</td>
            <td><i class="@item.Icon fa-2x"></i><a href="@item.LınkUrl" target="_blank">@item.Title</a></td>
            <td>
                <button onclick="deleteSocialMedia(@item.SocialMediaId)" class="btn btn-danger">Sil</button>
                <a asp-area="Admin" asp-controller="SocialMedia" asp-action="UpdateSocialMedia" asp-route-id="@item.SocialMediaId" class="btn btn-primary">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />

<a asp-area="Admin" asp-controller="SocialMedia" asp-action="CreateSocialMedia" class="btn btn-success">Yeni Sosyal Media Ekle</a>

<script>

      function deleteSocialMedia(id){
      Swal.fire({
        title: "Silmek İstediğine Emin Misiniz ?",
        text: "Bu işlemi geri alamazsınız !",
        icon: "warning",
        width: 450,
        showCancelButton: true,
        confirmButtonText: "Evet, Sil!",
        cancelButtonText: "İptal"
      }).then((result) => {
        if (result.isConfirmed) {

          Swal.fire({
            title: "Silindi!",
            text: "Silme işlemi başarıyla gerçekleşti.",
            icon: "success",
             width: 450,
            confirmButtonText: "Tamam"
          }).then(() => {
            window.location.href = "/Admin/SocialMedia/DeleteSocialMedia/" + id;
          });

        }
      });
    }
</script>


