@model UpdateSocialMediaDto
@{
    ViewData["Title"] = "Sosyal Medya Güncelleme";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<form method="post">
    <input type="hidden" asp-for="SocialMediaId">
    <label>Sosyal Medya Adı</label>
    <input type="text" asp-for="Title" class="form-control" />
    <br />
    <label>Sosyal Medya Url</label>
    <input type="text" asp-for="LınkUrl" class="form-control" />
    <br />
    <label>Icon</label>
    <input type="text" asp-for="Icon" class="form-control" />
    <br />
    <br />

    <button class="btn btn-outline-success">Güncelle</button>
</form>

