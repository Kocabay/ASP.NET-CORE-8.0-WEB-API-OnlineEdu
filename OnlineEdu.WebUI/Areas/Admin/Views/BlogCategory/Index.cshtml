@model List<ResultBlogCategoryDto>
@{
    ViewData["Title"] = "Blog Kategorileri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Blog Kategori Adı</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        count++;
        <tr>
            <td>@count</td>
            <td>@item.Name</td>
            <td>
                <button onclick="deleteBlogCategory(@item.BlogCategoryId)" class="btn btn-danger">Sil</button>
                <a asp-area="Admin" asp-controller="BlogCategory" asp-action="UpdateBlogCategory" asp-route-id="@item.BlogCategoryId" class="btn btn-primary">Güncelle</a>
            </td>
        </tr>
    }
</table>
<br />

<a asp-area="Admin" asp-controller="BlogCategory" asp-action="CreateBlogCategory" class="btn btn-success">Yeni Blog Ekle</a>


<script>

      function deleteBlogCategory(id){
      Swal.fire({
        title: "Silmek İstediğine Emin Misiniz ?",
        text: "Bu işlemi geri alamazsınız !",
        icon: "warning",
        width: 450,
        showCancelButton: true,
        confirmButtonText: "Evet, Sil!",
        cancelButtonText: "İptal"
      }).then((result) => {
        if (result.isConfirmed) {

          Swal.fire({
            title: "Silindi!",
            text: "Silme işlemi başarıyla gerçekleşti.",
            icon: "success",
             width: 450,
            confirmButtonText: "Tamam"
          }).then(() => {
            window.location.href = "/Admin/BlogCategory/DeleteBlogCategory/" + id;
          });

        }
      });
    }
</script>
